# Example configuration
# PostgreSQL
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3000
DATABASE_URL=postgresql://your_database_user:your_database_password@db:5432/your_database_name?schema=public
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=1d

# Frontend
FRONTEND_PORT=5173
